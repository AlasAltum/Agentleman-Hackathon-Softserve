# all required environment variables with placeholders and comments

# Root path used when the observability stack is composed from the repository root.
# Keep this value as ./observability when running:
# docker compose -f docker-compose.yml -f observability/docker-compose.yml ...
OBSERVABILITY_COMPOSE_ROOT=./observability

# Grafana admin credentials for the observability stack.
# These values are consumed by observability/docker-compose.yml with defaults,
# so local direct runs can still fall back to admin/admin if needed.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin


