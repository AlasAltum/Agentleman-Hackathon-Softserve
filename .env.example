# =============================================================================
# Root .env — single source of truth for the entire gentleman-stack
# =============================================================================
# Copy this file to .env and fill in the sensitive values marked with <REQUIRED>.
# Non-sensitive defaults are already set and should work out of the box locally.
# =============================================================================


# #############################################################################
# VARIABLES YOU MUST SET  (marked <REQUIRED>)
# #############################################################################

# Choose any password for the local Postgres instance.
POSTGRES_PASSWORD=<REQUIRED>

# Google AI Studio — create a free API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=<REQUIRED>

# Atlassian — log in at https://id.atlassian.com/manage-profile/security/api-tokens
# and generate a token. Use the email of the account that owns the token.
ATLASSIAN_EMAIL=<REQUIRED>
ATLASSIAN_API_TOKEN=<REQUIRED>

# Nylas — create an account and grab your API key + Grant ID from
# https://www.nylas.com/  (API keys → your app → Grants). You have to log in via OAuth
NYLAS_API_KEY=<REQUIRED>
NYLAS_GRANT_ID=<REQUIRED>

# Cohere - For reranking, get your API KEY from https://cohere.com/
COHERE_API_KEY=<OPTIONAL, BUT IDEAL>


# #############################################################################
# DEFAULTS — review before deploying, but work out of the box locally
# #############################################################################


# =============================================================================
# Shared PostgreSQL (used by backend + ecommerce-platform)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PORT=5432
POSTGRES_BDNAME=postgres


# =============================================================================
# Backend SRE Application
# =============================================================================
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
EXPOSED_APP_PORT=8000

# --- LLM Configuration ---
# Provider options: google
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=              # Only needed for custom endpoints
# LLM_API_KEY=               # Generic fallback

# --- Embeddings Configuration ---
# Provider options: google
EMBED_PROVIDER=google
EMBED_MODEL=gemini-embedding-2-preview
# EMBED_API_KEY=             # Defaults to GOOGLE_API_KEY / LLM_API_KEY

# --- Qdrant Vector DB ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=incidents

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=sre-workflow
MLFLOW_AUTOLOG_ENABLED=true

# --- Jira / Confluence (SRE integrations) ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=KAN
JIRA_ISSUE_TYPE=Task
JIRA_DEFAULT_LABELS=sre,observability
JIRA_TIMEOUT_SECONDS=15
# Optional: use this if your Jira workflow resolves issues with a custom transition name.
JIRA_RESOLVED_TRANSITION_NAME=Done
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki/
CONFLUENCE_SPACE_KEY=SRE

# There are two ways to check if Jira tickets have been resolved:
# 1) Webhook (ideal for production) — requires a reachable public endpoint.
# 2) Polling — checks every 45 seconds. Simpler, works locally.
POLL_JIRA_TICKETS=true

# --- Nylas Email Notifications ---
NYLAS_EMAIL_ADDRESS=alerts@example.com
NYLAS_EMAIL_REPLY_TO=alerts@example.com
NYLAS_TEAM_EMAIL_RECIPIENTS=sre-team@example.com
NYLAS_BASE_URL=https://api.us.nylas.com/v3
NYLAS_TIMEOUT_SECONDS=15
NYLAS_INCLUDE_TICKET_URL=false


# =============================================================================
# Ecommerce Platform (Medusa + Next.js Storefront)
# =============================================================================
ECOMMERCE_DB_NAME=medusa
ECOMMERCE_API_PORT=9000
ECOMMERCE_WEB_PORT=8001
ECOMMERCE_API_INTERNAL_URL=http://ecommerce-api:9000
ECOMMERCE_STORE_CORS=http://localhost:8001
ECOMMERCE_ADMIN_CORS=http://localhost:9000
ECOMMERCE_AUTH_CORS=http://localhost:9000,http://localhost:8001
ECOMMERCE_JWT_SECRET=supersecret
ECOMMERCE_COOKIE_SECRET=supersecret

# Medusa admin user (set to true on first run to create the admin)
ECOMMERCE_CREATE_ADMIN_USER=false
ECOMMERCE_ADMIN_EMAIL=test-admin@gmail.com
ECOMMERCE_ADMIN_PASSWORD=admin

# Storefront
NEXT_PUBLIC_BASE_URL=http://localhost:8001
NEXT_PUBLIC_INGEST_API_URL=http://localhost:8000
# Auto-populated by ecommerce-api-init bootstrap — leave empty on first run
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Stripe (optional — only needed if Stripe payments are enabled)
# NEXT_PUBLIC_STRIPE_KEY=
# NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
# NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=


# =============================================================================
# Observability Stack (Grafana, Prometheus, Loki, MLflow)
# =============================================================================
# Grafana admin credentials used on first login at http://localhost:3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
# Target used by the local test runner when running pytest against the observability stack
OBSERVABILITY_METRICS_TARGET=observability-test-runner:9464


# =============================================================================
# SRE Platform (report submission UI + API gateway)
# =============================================================================
# Secret key used to sign JWT tokens for the SRE API gateway
SRE_JWT_SECRET=supersecretkey
# Token expiry time in minutes
SRE_JWT_EXPIRE_MINUTES=60
# Internal URL of the backend SRE application
SRE_BACKEND_URL=http://hackaton-backend:8000
