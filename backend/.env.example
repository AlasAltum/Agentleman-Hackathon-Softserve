# Environment
APP_ENV=dev

# API
APP_HOST=0.0.0.0
APP_PORT=8000

# DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_BDNAME=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===========================================
# LLM Configuration
# ===========================================
# Provider options: google, openrouter, openai, anthropic, ollama, mock
LLM_PROVIDER=google

# API Keys (use the one for your provider)
# Google Gemini: GOOGLE_API_KEY or GEMINI_API_KEY
# OpenRouter: OPENROUTER_API_KEY
# OpenAI: OPENAI_API_KEY
# Anthropic: ANTHROPIC_API_KEY
# Generic: LLM_API_KEY
GOOGLE_API_KEY=your-google-api-key-here

# Model names per provider:
# Google (direct): gemini-2.5-flash (recommended)
# OpenRouter: google/gemini-2.5-flash, anthropic/claude-3-opus, openai/gpt-4o
# OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Anthropic: claude-3-sonnet, claude-3-opus
# Ollama: llama2, mistral
LLM_MODEL=gemini-2.5-flash

# ===========================================
# Embeddings Configuration
# ===========================================
# Provider options: google, openai, openrouter, local, mock
EMBED_PROVIDER=google

# Embedding models:
# Google: gemini-embedding-2-preview (recommended), text-embedding-004
# OpenAI/OpenRouter: text-embedding-3-small, text-embedding-3-large
EMBED_MODEL=gemini-embedding-2-preview

# Optional: Separate API key for embeddings (defaults to LLM_API_KEY)
# EMBED_API_KEY=your-embed-api-key

# Dockerfile
EXPOSED_APP_PORT=8000